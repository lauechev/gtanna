---
import BaseLayout from '@/layouts/BaseLayout.astro'
import logo from '@/assets/logo-gtanna.svg'
---

<BaseLayout title="Contacto">
  <main class="contacto">
    <img src={logo.src} alt="GTanna" class="contacto__logo" />
    <ul class="contacto__list">
      <li>
        <a href="https://linktr.ee/GTANNA" target="_blank" rel="noopener noreferrer"
          >plataformas música</a
        >
      </li>
      <li>
        <a href="https://substack.com/@gtanna" target="_blank" rel="noopener noreferrer">substack</a
        >
      </li>
      <li>
        <a
          href="https://www.instagram.com/isabelgtanna________/"
          target="_blank"
          rel="noopener noreferrer">instagram</a
        >
      </li>
      <li>
        <a href="https://www.tiktok.com/@gtanna___" target="_blank" rel="noopener noreferrer"
          >tiktok</a
        >
      </li>
      <li class="contacto__booking">
        <span>collabs - booking:</span>
        <a href="mailto:info.etrepia@gmail.com">info.etrepia@gmail.com</a>
      </li>
    </ul>
  </main>
</BaseLayout>

<style lang="scss">
  .contacto {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 90vh;
    padding: var(--spacing-2xl) var(--spacing-xl);

    &__logo {
      width: 300px;
      height: auto;
    }

    &__list {
      flex: 1;
      list-style: none;
      padding: 0;
      margin: 0;
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: var(--spacing-lg);
    }

    a {
      color: var(--dorado);
      text-decoration: none;
      font-family: var(--font-display);
      font-size: var(--font-size-3xl);
      letter-spacing: 0.05em;
      transition: opacity 0.2s ease;

      &:hover {
        opacity: 0.7;
      }
    }

    &__booking {
      margin-top: var(--spacing-3xl);
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xs);

      span {
        color: var(--dorado);
        font-family: var(--font-display);
        font-size: var(--font-size-2xl);
        letter-spacing: 0.05em;
      }

      a {
        font-family: var(--font-body);
        font-size: var(--font-size-lg);
        color: var(--oliva);
      }
    }
  }
</style>
