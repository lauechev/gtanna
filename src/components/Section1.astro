---
interface Props {
  title: string
  imageSrc?: ImageMetadata
  imageAlt?: string
  columns?: number
}

const { title, imageSrc, imageAlt = '', columns = 1 } = Astro.props
---

<section class="section">
  <h2 class="section__title">{title}</h2>
  <div class="section__content">
    {imageSrc && <img src={imageSrc.src} alt={imageAlt} class="section__image" />}
    <div class="section__text" style={`grid-template-columns: repeat(${columns}, 1fr)`}>
      <slot />
    </div>
  </div>
</section>

<style lang="scss">
  .section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl);
    padding: 5rem;
    width: 98%;

    &__title {
      font-family: var(--font-display);
      color: var(--dorado);
      font-size: var(--font-size-3xl);
      font-weight: 400;
    }

    &__content {
      display: flex;
      gap: var(--spacing-xl);
      align-items: flex-start;
    }

    &__image {
      width: 300px;
      height: auto;
      object-fit: cover;
      flex-shrink: 0;
    }

    &__text {
      color: var(--blanco);
      font-family: var(--font-body);
      font-size: var(--font-size-base);
      line-height: var(--line-height-base);
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-xl);
      align-items: start;

      :global(p) {
        margin-bottom: var(--spacing-md);
      }
    }
  }
</style>
