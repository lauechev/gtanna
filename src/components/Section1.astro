---
interface Props {
  title: string
  imageSrc?: ImageMetadata
  imageAlt?: string
}

const { title, imageSrc, imageAlt = '' } = Astro.props
---

<section class="section">
  <h2 class="section__title">{title}</h2>
  <div class="section__content">
    {imageSrc && <img src={imageSrc.src} alt={imageAlt} class="section__image" />}
    <div class="section__text">
      <slot />
    </div>
  </div>
</section>

<style lang="scss">
  .section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl);
    padding: 5rem;
    width: 98%;

    &__title {
      font-family: var(--font-display);
      color: var(--blanco);
      font-size: var(--font-size-2xl);
      font-weight: 400;
    }

    &__content {
      display: flex;
      gap: var(--spacing-xl);
      align-items: flex-start;
    }

    &__image {
      width: 300px;
      height: auto;
      object-fit: cover;
      flex-shrink: 0;
    }

    &__text {
      color: var(--blanco);
      font-family: var(--font-body);
      font-size: var(--font-size-base);
      line-height: var(--line-height-base);
    }
  }
</style>
