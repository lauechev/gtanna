---
import Head from '@/components/Head.astro'
import Nav from '@/components/Nav.astro'
import '@/styles/global.scss'

interface Props {
  title?: string
  description?: string
}

const { title = 'Astro Starter', description = 'A production-ready Astro starter template.' } =
  Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} />
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>
