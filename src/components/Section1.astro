---
interface Props {
  title: string
  imageSrc?: ImageMetadata | { src: string }
  imageAlt?: string
  columns?: number
}

const { title, imageSrc, imageAlt = '', columns = 1 } = Astro.props
---

<section class="section">
  <h2 class="section__title">{title}</h2>
  <div class="section__text" style={`grid-template-columns: repeat(${columns}, 1fr)`}>
    <slot />
  </div>
  {imageSrc && <img src={imageSrc.src} alt={imageAlt} class="section__image" />}
</section>

<style lang="scss">
  .section {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-2xl);
    padding: 5rem;
    width: 100%;

    &__title {
      font-family: var(--font-display);
      color: var(--dorado);
      font-size: var(--font-size-4xl);
      font-weight: 400;
      margin-bottom: var(--spacing-2xl);
    }

    &__image {
      width: 300px;
      height: auto;
      object-fit: cover;
    }

    &__text {
      color: var(--beige);
      font-family: var(--font-body);
      font-size: var(--font-size-base);
      line-height: var(--line-height-base);
      display: grid;
      gap: var(--spacing-xl);
      align-items: start;

      :global(p) {
        margin-bottom: var(--spacing-md);
      }
    }
  }
</style>
