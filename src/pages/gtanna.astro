---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="Gtanna">
  <main class="gtanna-hub">
    <a href="/arquetipo" class="gtanna-hub__link">arquetipo</a>
    <a href="/proyectoGtanna" class="gtanna-hub__link">proyecto gtanna</a>
  </main>
</BaseLayout>

<style lang="scss">
  .gtanna-hub {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: var(--spacing-2xl);

    &__link {
      font-family: var(--font-display);
      color: var(--dorado);
      font-size: var(--font-size-4xl);
      text-decoration: none;
      text-transform: lowercase;

      &:hover {
        opacity: 0.8;
      }
    }
  }
</style>
