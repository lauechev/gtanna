---
import { Image } from 'astro:assets'
import heroImage from '@/assets/hero-gtanna3.jpg'
import logoImage from '@/assets/logo-gtanna.svg'
---

<section class="hero">
  <Image
    src={heroImage}
    alt=""
    class="hero__bg"
    width={1920}
    format="webp"
    quality={90}
    loading="eager"
  />
  <img src={logoImage.src} alt="Gtanna logo" class="hero__logo" />
  <div class="hero__animation">
    <canvas class="hero__spiral" id="spiral-canvas"></canvas>
  </div>
</section>

<script>
  import { initSpiralAnimation } from '@/scripts/spiral-animation'
  import { initSpiralAnimation2 } from '@/scripts/spiral-animation2'
  initSpiralAnimation2('spiral-canvas')
</script>

<style lang="scss">
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;

    &__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
    }

    &__logo {
      position: absolute;
      top: 2rem;
      left: 50%;
      transform: translateX(-50%);
      max-width: 200px;
      height: auto;
      z-index: 2;
    }

    &__animation {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0.7;
    }

    &__spiral {
      display: block;
      max-width: 100%;
      height: auto;
    }
  }
</style>
